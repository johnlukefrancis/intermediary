{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Rust: check",
      "type": "shell",
      "command": "cargo check",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "build"
    },
    {
      "label": "Rust: build",
      "type": "shell",
      "command": "cargo build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "build"
    },
    {
      "label": "Rust: test",
      "type": "shell",
      "command": "cargo test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "test"
    },
    {
      "label": "Rust: clippy",
      "type": "shell",
      "command": "cargo clippy",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "test"
    },
    {
      "label": "Tauri: dev (WSL)",
      "detail": "Linux-target dev task. For /mnt/<drive> repo roots, prefer Tauri: dev (Windows) for watcher reliability.",
      "type": "shell",
      "command": "pnpm tauri dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "group": "build"
    },
    {
      "label": "Sync: Windows mirror (WSL)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/windows/sync_to_windows.sh",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "build"
    },
    {
      "label": "Sync: watch (WSL)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/windows/watch_sync_to_windows.sh",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "group": "build"
    },
    {
      "label": "WSL Agent: dev",
      "type": "process",
      "command": "wsl.exe",
      "args": [
        "-d",
        "${input:intermediaryWslDistro}",
        "--",
        "bash",
        "-lc",
        "export PATH=\"/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\"; export INTERMEDIARY_AGENT_PORT=3142; export INTERMEDIARY_WINDOWS_LOCALAPPDATA='${input:intermediaryWindowsLocalAppDataWslPath}'; set -e; if [ -s \"$HOME/.cargo/env\" ]; then . \"$HOME/.cargo/env\"; else echo \"cargo env not found at $HOME/.cargo/env\" >&2; exit 1; fi; cd '${workspaceFolder}'; command -v cargo >/dev/null 2>&1 || { echo \"cargo not available in PATH\" >&2; exit 1; }; bash ./scripts/dev/run_wsl_agent_dev.sh"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "wsl-agent",
          "pattern": [
            {
              "regexp": "^(.*):(\\d+):(\\d+):\\s+(.*)$",
              "file": 1,
              "line": 2,
              "column": 3,
              "message": 4
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "WebSocket server started",
            "endsPattern": "WebSocket server started"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "group": "build"
    },
    {
      "label": "Tauri: dev (Windows)",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$ErrorActionPreference='Stop'; $wslPathForUnc = '${workspaceFolder}'.TrimStart('/').Replace('/','\\'); $scriptPath = \"\\\\wsl$\\${input:intermediaryWslDistro}\\$wslPathForUnc\\scripts\\windows\\run_windows_tauri_task.ps1\"; & $scriptPath -WindowsMirrorPath '${input:intermediaryWindowsMirrorPath}' -WslRepoPath '${workspaceFolder}' -WslDistro '${input:intermediaryWslDistro}' -Mode 'dev' -WindowsLocalAppDataWslPath '${input:intermediaryWindowsLocalAppDataWslPath}'"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Tauri: dev (Windows, watch + sync)",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$ErrorActionPreference='Stop'; $wslPathForUnc = '${workspaceFolder}'.TrimStart('/').Replace('/','\\'); $scriptPath = \"\\\\wsl$\\${input:intermediaryWslDistro}\\$wslPathForUnc\\scripts\\windows\\run_windows_tauri_task.ps1\"; & $scriptPath -WindowsMirrorPath '${input:intermediaryWindowsMirrorPath}' -WslRepoPath '${workspaceFolder}' -WslDistro '${input:intermediaryWslDistro}' -Mode 'dev-watch-sync' -WindowsLocalAppDataWslPath '${input:intermediaryWindowsLocalAppDataWslPath}'"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "group": "build"
    },
    {
      "label": "Tauri: build installer (Windows)",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$ErrorActionPreference='Stop'; $wslPathForUnc = '${workspaceFolder}'.TrimStart('/').Replace('/','\\'); $scriptPath = \"\\\\wsl$\\${input:intermediaryWslDistro}\\$wslPathForUnc\\scripts\\windows\\run_windows_tauri_task.ps1\"; & $scriptPath -WindowsMirrorPath '${input:intermediaryWindowsMirrorPath}' -WslRepoPath '${workspaceFolder}' -WslDistro '${input:intermediaryWslDistro}' -Mode 'build-installer'"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "group": "build"
    },
    {
      "label": "Zip: bundles",
      "type": "shell",
      "command": "node scripts/zip/zip_bundles.mjs",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "build"
    },
    {
      "label": "Zip: docs only",
      "type": "shell",
      "command": "node scripts/zip/zip_bundles.mjs --docs",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "build"
    },
    {
      "label": "Downscale noise",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/textures/downscale.sh",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "build"
    }
  ],
  "inputs": [
    {
      "id": "intermediaryWindowsMirrorPath",
      "type": "promptString",
      "description": "Windows mirror directory used by sync and Tauri Windows tasks",
      "default": "D:\\code\\intermediary"
    },
    {
      "id": "intermediaryWslDistro",
      "type": "promptString",
      "description": "WSL distro used by sync and agent tasks",
      "default": "Ubuntu"
    },
    {
      "id": "intermediaryWindowsLocalAppDataWslPath",
      "type": "promptString",
      "description": "Optional /mnt/... path to Windows LocalAppData for deterministic ws_auth lookup; leave blank to auto-detect",
      "default": ""
    }
  ]
}
