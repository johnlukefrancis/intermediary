{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Rust: check",
      "type": "shell",
      "command": "cargo check",
      "options": {
        "cwd": "${workspaceFolder}/src-tauri"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "build"
    },
    {
      "label": "Rust: build",
      "type": "shell",
      "command": "cargo build",
      "options": {
        "cwd": "${workspaceFolder}/src-tauri"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "build"
    },
    {
      "label": "Rust: test",
      "type": "shell",
      "command": "cargo test",
      "options": {
        "cwd": "${workspaceFolder}/src-tauri"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "test"
    },
    {
      "label": "Rust: clippy",
      "type": "shell",
      "command": "cargo clippy",
      "options": {
        "cwd": "${workspaceFolder}/src-tauri"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "test"
    },
    {
      "label": "Tauri: dev (WSL)",
      "type": "shell",
      "command": "pnpm tauri dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "group": "build"
    },
    {
      "label": "Sync: Windows mirror (WSL)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/windows/sync_to_windows.sh",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "build"
    },
    {
      "label": "Sync: watch (WSL)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/windows/watch_sync_to_windows.sh",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "group": "build"
    },
    {
      "label": "Tauri: dev (Windows)",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$env:INTERMEDIARY_WIN_PATH='D:\\code\\intermediary'; $env:INTERMEDIARY_WSL_PATH='/home/johnf/code/intermediary'; $env:INTERMEDIARY_WSL_DISTRO='Ubuntu'; $env:INTERMEDIARY_LOG_DIR='\\\\wsl$\\Ubuntu\\home\\johnf\\code\\intermediary\\logs'; wsl.exe -d Ubuntu -- bash -lc 'cd /home/johnf/code/intermediary && ./scripts/windows/sync_to_windows.sh'; cd $env:INTERMEDIARY_WIN_PATH; if (-not (Test-Path node_modules)) { pnpm install }; New-Item -ItemType Directory -Force $env:INTERMEDIARY_LOG_DIR | Out-Null; pnpm tauri dev"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Tauri: dev (Windows, watch + sync)",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$env:INTERMEDIARY_WIN_PATH='D:\\code\\intermediary'; $env:INTERMEDIARY_WSL_PATH='/home/johnf/code/intermediary'; $env:INTERMEDIARY_WSL_DISTRO='Ubuntu'; $env:INTERMEDIARY_LOG_DIR='\\\\wsl$\\Ubuntu\\home\\johnf\\code\\intermediary\\logs'; $winPath = $env:INTERMEDIARY_WIN_PATH; wsl.exe -d Ubuntu -- bash -lc 'cd /home/johnf/code/intermediary && ./scripts/windows/sync_to_windows.sh'; Start-Process wsl.exe -ArgumentList '-d Ubuntu -- bash -lc \"cd /home/johnf/code/intermediary && ./scripts/windows/watch_sync_to_windows.sh\"'; if (-not (Test-Path $winPath)) { Write-Error \"Sync did not create $winPath\"; exit 1 }; Set-Location $winPath; if (-not (Test-Path node_modules)) { pnpm install }; New-Item -ItemType Directory -Force $env:INTERMEDIARY_LOG_DIR | Out-Null; pnpm tauri dev"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "group": "build"
    },
    {
      "label": "Tauri: build installer (Windows)",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$env:INTERMEDIARY_WIN_PATH='D:\\code\\intermediary'; $env:INTERMEDIARY_WSL_PATH='/home/johnf/code/intermediary'; $env:INTERMEDIARY_WSL_DISTRO='Ubuntu'; wsl.exe -d Ubuntu -- bash -lc 'cd /home/johnf/code/intermediary && ./scripts/windows/sync_to_windows.sh'; cd $env:INTERMEDIARY_WIN_PATH; if (-not (Test-Path node_modules)) { pnpm install }; pnpm tauri build"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "group": "build"
    },
    {
      "label": "Zip: bundles",
      "type": "shell",
      "command": "node scripts/zip/zip_bundles.mjs",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "build"
    },
    {
      "label": "Zip: docs only",
      "type": "shell",
      "command": "node scripts/zip/zip_bundles.mjs --docs",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      },
      "group": "build"
    }
  ]
}
